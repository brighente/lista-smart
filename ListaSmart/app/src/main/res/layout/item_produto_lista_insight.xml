<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#252530"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPosicaoProdutoListaInsight"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_chip_warning"
            android:gravity="center"
            android:text="1º"
            android:textColor="@color/brand_dark_gray"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNomeProdutoListaInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Arroz Branco"
                style="@style/DashboardItemTitle" />

            <TextView
                android:id="@+id/tvCategoriaProdutoListaInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mercearia"
                style="@style/DashboardItemMeta" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#1F1F28"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvValorPrincipalProdutoListaInsight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="9"
            android:textColor="@color/brand_yellow"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRotuloPrincipalProdutoListaInsight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="listas com este produto"
            style="@style/DashboardCardSubtitle" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvResumoProdutoListaInsight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Também soma 18 unidades adicionadas no total."
        style="@style/DashboardCardDescription" />
</LinearLayout>