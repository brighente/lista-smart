<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/brand_dark_gray"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imgProduto"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#2A2A32"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_report_image"
        android:layout_marginBottom="8dp"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/txtNomeProduto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nome do Produto"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:maxLines="1"
        android:ellipsize="end"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/txtMercadoProduto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mercado"
            android:textSize="12sp"
            android:textColor="#AAAAAA"/>

        <TextView
            android:id="@+id/txtTipoRegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Cupom"
            android:textSize="11sp"
            android:textStyle="italic"
            android:textColor="@color/brand_yellow"/> </RelativeLayout>

    <TextView
        android:id="@+id/txtPrecoProduto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="R$ 00,00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/brand_yellow"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btnAdicionarProduto"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:text="Adicionar"
        android:textStyle="bold"
        android:textColor="@color/brand_dark_gray"
        android:backgroundTint="@color/brand_yellow" />

</LinearLayout>
</androidx.cardview.widget.CardView>