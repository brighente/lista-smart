<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTituloCadastroMercado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cadastrar Supermercado"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etNomeResponsavel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do responsável"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:backgroundTint="@color/brand_yellow"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etEmailMercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:backgroundTint="@color/brand_yellow"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etSenhaMercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Senha"
            android:inputType="textPassword"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:backgroundTint="@color/brand_yellow"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etNomeMercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do mercado"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:backgroundTint="@color/brand_yellow"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etEnderecoMercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Endereço"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:backgroundTint="@color/brand_yellow"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/ivPreviewMercado"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:background="#2A2A32"
            android:padding="8dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

        <Button
            android:id="@+id/btnSelecionarImagem"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Selecionar imagem"
            android:textStyle="bold"
            android:textColor="@color/brand_dark_gray"
            android:backgroundTint="@color/brand_yellow"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etImagemMercado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URI da imagem"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:backgroundTint="@color/brand_yellow"
            android:focusable="false"
            android:clickable="false"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnCadastrarMercado"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Cadastrar supermercado"
            android:textStyle="bold"
            android:textColor="@color/brand_dark_gray"
            android:backgroundTint="@color/brand_yellow" />
    </LinearLayout>
</ScrollView>