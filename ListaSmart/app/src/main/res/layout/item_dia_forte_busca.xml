<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#252530"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNomeDiaForteBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sábado"
            style="@style/DashboardItemTitle" />

        <TextView
            android:id="@+id/tvResumoDiaForteBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Dia com maior concentração de buscas."
            style="@style/DashboardCardDescription" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTotalDiaForteBusca"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip_warning"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="12 buscas"
        android:textColor="@color/brand_dark_gray"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>