<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="#23232D"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNomeProdutoOportunidade"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Produto"
            style="@style/DashboardItemTitle" />

        <TextView
            android:id="@+id/tvStatusOportunidade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="28dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="Status"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvMetaOportunidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Categoria • 0 buscas"
        style="@style/DashboardItemMeta" />

    <TextView
        android:id="@+id/tvPrecoMercadoOportunidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Seu preço atual: R$ 0,00"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDataPrecoMercadoOportunidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Atualizado em 00/00/0000 00:00"
        style="@style/DashboardCardDescription" />

    <TextView
        android:id="@+id/tvReferenciaOportunidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Melhor preço atual: R$ 0,00"
        style="@style/DashboardCardSubtitle" />

    <TextView
        android:id="@+id/tvDataReferenciaOportunidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Preço de referência atualizado em 00/00/0000 00:00"
        style="@style/DashboardCardDescription" />

    <TextView
        android:id="@+id/tvResumoStatusOportunidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Resumo da situação competitiva do produto."
        style="@style/DashboardCardDescription" />
</LinearLayout>