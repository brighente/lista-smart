<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/brand_background_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/brand_dark_gray"
            app:title="Lista Smart"
            app:titleTextColor="@color/brand_yellow"
            app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/layout_conteudo_produtos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvNomeUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Olá, Usuário"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:padding="4dp"/>
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/layoutAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Painel do Administrador"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumo rápido do sistema"
                        android:textSize="16sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="24dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="#1F1F27"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mercados"
                                android:textColor="#AAAAAA"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvTotalMercadosAdmin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textColor="@color/brand_yellow"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="#1F1F27"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Consumidores"
                                android:textColor="#AAAAAA"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvTotalConsumidoresAdmin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textColor="@color/brand_yellow"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escolha uma ação rápida:"
                        android:textSize="16sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginBottom="24dp" />

                    <Button
                        android:id="@+id/btnAdminCadastrarMercado"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Cadastrar Mercado"
                        android:textStyle="bold"
                        android:textColor="@color/brand_dark_gray"
                        android:backgroundTint="@color/brand_yellow"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnAdminGerenciarMercados"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Gerenciar Mercados"
                        android:textStyle="bold"
                        android:textColor="@color/brand_dark_gray"
                        android:backgroundTint="@color/brand_yellow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutFiltrosProdutos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnNovaLista"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:text="Nova Lista de Compras"
                        android:textStyle="bold"
                        android:textColor="@color/brand_dark_gray"
                        android:backgroundTint="@color/brand_yellow" />

                    <TextView
                        android:id="@+id/tvListaAtiva"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Nenhuma lista selecionada"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Spinner
                            android:id="@+id/spinnerMercado"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:theme="@style/ThemeOverlay.AppCompat.Dark"
                            android:backgroundTint="@color/brand_yellow"/>

                        <Spinner
                            android:id="@+id/spinnerCategoria"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:theme="@style/ThemeOverlay.AppCompat.Dark"
                            android:backgroundTint="@color/brand_yellow"/>
                    </LinearLayout>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvProdutos"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/brand_dark_gray"
        app:menu="@menu/activity_home_menu"
        app:itemTextColor="@color/white"
        app:itemIconTint="@color/brand_yellow"
        app:itemShapeInsetStart="8dp"
        app:itemShapeInsetEnd="8dp"
        app:headerLayout="@android:layout/preference_category"/>

</androidx.drawerlayout.widget.DrawerLayout>