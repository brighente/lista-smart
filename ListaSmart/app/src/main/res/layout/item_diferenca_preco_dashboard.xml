<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="#23232D"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvNomeProdutoDiferenca"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Produto"
        style="@style/DashboardItemTitle" />

    <TextView
        android:id="@+id/tvValorDiferenca"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Diferença: R$ 0,00"
        android:textColor="@color/brand_yellow"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMercadoMaisBarato"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Mais barato em Mercado • R$ 0,00"
        style="@style/DashboardCardDescription" />

    <TextView
        android:id="@+id/tvMercadoMaisCaro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Mais caro em Mercado • R$ 0,00"
        style="@style/DashboardCardDescription" />
</LinearLayout>
