<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="28dp"
        android:layout_height="match_parent"
        android:gravity="top|center_horizontal"
        android:orientation="vertical">

        <View
            android:layout_width="2dp"
            android:layout_height="10dp"
            android:background="#4B4B55" />

        <View
            android:id="@+id/viewPontoTimeline"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_timeline_dot" />

        <View
            android:id="@+id/viewLinhaInferior"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginTop="4dp"
            android:background="#4B4B55" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutConteudoHistorico"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="#23232D"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvDataHistoricoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="21/06/2026"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPrecoHistoricoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="R$ 9,90"
            android:textColor="@color/brand_yellow"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProdutosHistoricoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="104 produtos na média"
            android:textColor="#CCCCCC"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>