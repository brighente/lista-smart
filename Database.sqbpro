-- Criando os cabeçalhos das listas para os usuários 2 (João) e 3 (Maria)
INSERT INTO lista_compras (id_usuario, nome_lista, data_criacao) VALUES 
(2, 'Churrasco de Domingo', '2026-05-10'),
(3, 'Compras do Mês', '2026-05-15'),
(2, 'Café da Tarde', '2026-06-01');

-- Itens da Lista 1 (Churrasco do João)
INSERT INTO item_lista (id_lista, id_produto, quantidade) VALUES 
(1, 11, 3),  -- 3x Coca-Cola 2L
(1, 13, 24), -- 24x Cerveja Pilsen
(1, 1, 10),  -- 10x Pão Francês
(1, 23, 2);  -- 2x Tomate

-- Itens da Lista 2 (Compras da Maria)
INSERT INTO item_lista (id_lista, id_produto, quantidade) VALUES 
(2, 31, 2),  -- 2x Sabão em Pó
(2, 32, 3),  -- 3x Detergente Líquido (ID 32)
(2, 19, 12), -- 12x Leite Integral (ID 19)
(2, 22, 1);  -- 1x Banana Prata (ID 22)

-- Itens da Lista 3 (Café do João)
INSERT INTO item_lista (id_lista, id_produto, quantidade) VALUES 
(3, 2, 1),   -- 1x Pão de Forma (ID 2)
(3, 3, 1),   -- 1x Bolo de Chocolate (ID 3)
(3, 12, 2);  -- 2x Suco de Laranja (ID 12)
INSERT INTO historico_pesquisa (id_usuario, id_produto, data_pesquisa) VALUES 
(2, 11, '2026-05-01'), (3, 11, '2026-05-02'), (2, 11, '2026-05-05'), -- Coca-Cola bombando nas buscas
(3, 31, '2026-05-03'), (2, 31, '2026-05-08'),                       -- Sabão em Pó
(2, 13, '2026-05-04'), (3, 13, '2026-05-09'), (2, 13, '2026-05-11'), -- Cerveja Pilsen
(3, 1, '2026-05-06'),  (2, 1, '2026-05-10'),                        -- Pão Francês
(2, 23, '2026-05-07'),                                              -- Tomate
(3, 19, '2026-05-12'), (2, 19, '2026-05-14'),                       -- Leite
(3, 3, '2026-05-15'),  (2, 3, '2026-05-16'),  (3, 3, '2026-05-18'),  -- Bolo de Chocolate
(2, 4, '2026-05-20'),  (3, 5, '2026-05-22'),                        -- Croissant e Pão de Queijo
(2, 12, '2026-05-25'), (3, 12, '2026-05-26');                       -- Suco de Laranja
SELECT tipo_registro, COUNT(*) as quantidade 
FROM registro_preco 
GROUP BY tipo_registro;</sql><current_tab id="0"/></tab_sql></sqlb_project>
