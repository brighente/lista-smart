 index="2" value="29"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="usuario" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="67"/><column index="2" value="132"/><column index="3" value="187"/><column index="4" value="70"/><column index="5" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">-- Registros para a Coca-Cola 2L (ID 11) - Variação de preço e diferentes mercados
INSERT INTO registro_preco (id_produto, id_mercado, id_usuario, preco, data_registro, tipo_registro) VALUES 
(11, 1, 2, 9.50, '2026-05-10', 'CUPOM'),  -- Bistek
(11, 2, 3, 10.20, '2026-05-12', 'MANUAL'), -- Angeloni
(11, 3, 2, 8.99, '2026-05-15', 'CUPOM'),  -- Russel
(11, 4, 3, 9.35, '2026-05-20', 'CUPOM'),  -- Giassi
(11, 5, 2, 9.80, '2026-05-25', 'MANUAL'), -- Combo
(11, 1, 3, 9.60, '2026-06-01', 'CUPOM'),  -- Bistek (Aumento de preço)
(11, 3, 2, 8.89, '2026-06-03', 'CUPOM');  -- Russel (Queda de preço)

